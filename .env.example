# --- Postgres ---
DATABASE_URL=postgres://postgres:postgres@localhost:5444/runner_mobile

# --- Runner backend ---
RUNNER_BACKEND=https://api.runner.now

# --- Anthropic / Managed Agents ---
ANTHROPIC_API_KEY=
ANTHROPIC_BETA=managed-agents-2026-04-01

# --- Spectrum (Photon iMessage provider) ---
SPECTRUM_PROJECT_ID=
SPECTRUM_PROJECT_SECRET=

# --- Managed Agents environment (lazy-created if blank) ---
MANAGED_AGENT_ENVIRONMENT_ID=

# --- Cron auth ---
CRON_SHARED_SECRET=replace-me

# --- Public URLs (Railway will set these) ---
SERVER_PUBLIC_URL=http://localhost:4001
MICROSITE_PUBLIC_URL=http://localhost:4173

# --- Microsite (Vite, build-time) ---
VITE_SERVER_URL=http://localhost:4001
VITE_RUNNER_BACKEND=https://api.runner.now
